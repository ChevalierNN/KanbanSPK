<Page x:Class="FTSControl.Pages.Dia"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FTSControl.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dia">

    <Grid Grid.Column="1" Grid.Row="2" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Статусы задач" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,5"/>

        <Canvas x:Name="PieChartCanvas" Width="200" Height="200" HorizontalAlignment="Center" Margin="0,10,0,163" Grid.Row="1"/>

        <Button Content="Назад" Margin="542,0,51,0" Grid.Row="2" VerticalAlignment="Center" Height="28" Click="Back_Click"/>
        <TextBlock FontSize="14" x:Name="AllQuests" HorizontalAlignment="Left" Margin="581,24,0,178" TextWrapping="Wrap" Width="166" Grid.RowSpan="2"/>


    </Grid>
</Page>
