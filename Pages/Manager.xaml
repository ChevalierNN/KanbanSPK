<Page x:Class="FTSControl.Pages.Manager"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FTSControl.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Manager">

    <Grid>
        <!--Разметка-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600*" />
            <ColumnDefinition Width="200*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="190*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="30*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="110*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TBHello" Text="" TextAlignment="Center" Grid.Row="0" Grid.Column="1"></TextBlock>

        <StackPanel Grid.Column="1" Grid.RowSpan="5" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Выгрузить данные json " Click="Export"/>
            <Button Content="Выгрузить данных Excel" Click="ExportExcel"/>
            <Button Content="Создать задачу" Height="50" Width="200" Click="ButtonAdd_Click"/>
            <Button Content="Диагармма" Height="50" Width="200" Click="Dia_Click"/>
            <Button Content="Выйти из аккаунта" Height="50" Width="200" Click="ButtonBack_Click"/>
        </StackPanel>

        <!--Таблицы для отображения задач-->
        <TabControl Grid.RowSpan="5" Grid.Column="0" x:Name="TabMain">
            <TabItem Header="В работе">
                <DataGrid x:Name="DGridInProcess" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding TaskID}" Width="50"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
                        <DataGridTextColumn Header="Срочность" Binding="{Binding TaskPriorities.PriorityName}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Низкий">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Средний">
                                            <Setter Property="Foreground" Value="#D4A017"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Высокий">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Дедлайн" Binding="{Binding DueDate, StringFormat='dd.MM.yy HH:mm'}"  Width="120"/>
                        <DataGridTextColumn Header="Создана"  Binding="{Binding CreatedAt, StringFormat='dd.MM.yy HH:mm'}"  Width="120"/>
                        <DataGridTextColumn Header="Исполнитель"   Binding="{Binding Users.LastName}"  Width="100"/>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Комментарии" Click="ButtonComments_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Редактировать" Click="ButtonEditTask_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="На проверке">
                <DataGrid x:Name="DGridOnReview" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding TaskID}" Width="60"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Назначена" Binding="{Binding UpdatedAt, StringFormat='dd.MM.yy HH:mm'}" Width="120"/>
                        <DataGridTextColumn Header="Исполнитель" Binding="{Binding Users.LastName}" Width="120"/>
                        <DataGridTextColumn Header="Срочность" Binding="{Binding TaskPriorities.PriorityName}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Низкий">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Средний">
                                            <Setter Property="Foreground" Value="#D4A017"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Высокий">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Комментарии" Click="ButtonComments_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Редактировать" Click="ButtonEditTask_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Готово">
                <DataGrid x:Name="DGridDone" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding TaskID}" Width="60"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Исполнитель" Binding="{Binding Users.LastName}" Width="120"/>
                        <DataGridTextColumn Header="Срочность" Binding="{Binding TaskPriorities.PriorityName}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Низкий">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Средний">
                                            <Setter Property="Foreground" Value="#D4A017"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TaskPriorities.PriorityName}" Value="Высокий">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Комментарии" Click="ButtonComments_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Редактировать" Click="ButtonEditTask_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
