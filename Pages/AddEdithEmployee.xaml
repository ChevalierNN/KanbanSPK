<Page x:Class="FTSControl.Pages.AddEdithEmployee"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FTSControl.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEdithEmployee">

    <Grid>
        <!--Разметка-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100*" />
            <ColumnDefinition Width="500*" />
            <ColumnDefinition Width="500*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="50*" />
        </Grid.RowDefinitions>

        <!--Поля-->
        <Label Content="Фамилия" FontSize="15" FontWeight="Bold" Grid.Column="1" Target="{Binding ElementName=TBLastName}" HorizontalAlignment="Right"   />
        <TextBox x:Name="TBLastName" Text="{Binding LastName}" Grid.Row="0" Grid.Column="2" Margin="1" />

        <Label Content="Имя" Grid.Row="1" FontSize="15" FontWeight="Bold" Grid.Column="1" Target="{Binding ElementName=TBFirstName}" HorizontalAlignment="Right" />
        <TextBox x:Name="TBFirstName" Text="{Binding FirstName}" Grid.Row="1" Grid.Column="2" Margin="1"/>

        <Label Content="Отчество" FontSize="15" FontWeight="Bold" Grid.Row="2" Grid.Column="1" Target="{Binding ElementName=TBPatronymic}" HorizontalAlignment="Right"/>
        <TextBox x:Name="TBPatronymic" Text="{Binding Patronymic}" Grid.Row="2" Grid.Column="2" Margin="1"/>

        <Label Content="Логин" FontSize="15" FontWeight="Bold" Grid.Row="3" Grid.Column="1" Target="{Binding ElementName=TBLoginNew}" HorizontalAlignment="Right" />
        <TextBox x:Name="TBLoginNew" Text="{Binding Login}" Grid.Row="3" Grid.Column="2" Margin="1"/>

        <Label Content="Пароль" FontSize="15" FontWeight="Bold" Grid.Row="4" Grid.Column="1" Target="{Binding ElementName=TBPasswordNew}" HorizontalAlignment="Right" />
        <TextBox x:Name="TBPasswordNew"  Text="{Binding Password}" Grid.Row="4" Grid.Column="2" Margin="1"/>

        <Label Content="Почта" FontSize="15" FontWeight="Bold" Grid.Row="5" Grid.Column="1" Target="{Binding ElementName=TBEmail}" HorizontalAlignment="Right"/>
        <TextBox x:Name="TBEmail" Text="{Binding Email}" Grid.Row="5" Grid.Column="2" Margin="1"/>

        <Label Content="Телефон" FontSize="15" FontWeight="Bold" Grid.Row="6" Grid.Column="1" Target="{Binding ElementName=TBPhone}" HorizontalAlignment="Right" />
        <TextBox x:Name="TBPhone" Text="{Binding Phone}" Grid.Row="6" Grid.Column="2" Margin="1"/>

        <Label Content="Должность" FontWeight="Bold" FontSize="15" Grid.Row="8" Grid.Column="1" Target="{Binding ElementName=CBRole}" HorizontalAlignment="Left" Margin="264,0,0,0" VerticalAlignment="Center"/>
        <ComboBox x:Name="CBRole" SelectedValue="{Binding RoleID}" DisplayMemberPath="RoleName" SelectedValuePath="RoleID" Grid.Row="8" Grid.Column="2" Margin="1"/>

        <Label Content="Департамент" FontWeight="Bold" FontSize="15" Grid.Row="7" Grid.Column="1" Height="31" VerticalAlignment="Center" HorizontalAlignment="Left" Width="106" Margin="253,0,0,0"/>
        <ComboBox x:Name="CBDepartments" SelectedValue="{Binding DepartmentID}" DisplayMemberPath="DepartmentName" SelectedValuePath="DepartmentID" Grid.Row="7" Grid.Column="2" Margin="1"/>

        <Label Content="Статус" FontWeight="Bold" FontSize="15" Grid.Row="9" Grid.Column="1" Target="{Binding ElementName=CBStatus}"  HorizontalAlignment="Right" />
        <ComboBox x:Name="CBStatus" SelectedValue="{Binding StatusID}" DisplayMemberPath="StatusName" SelectedValuePath="StatusID" Grid.Row="9" Grid.Column="2" Margin="1"/>

        <!--Кнопки-->
        <Button Content="OK" Grid.Row="10" Grid.Column="2" Click="ButtonOKAddEdit_Click" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="21,0,0,0" Width="58"/>
        <Button Content="Выйти без изменений" Grid.Row="10" Grid.Column="2" Click="ButtonBack_Click" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="106,0,0,0" Width="132"/>
    </Grid>
</Page>
